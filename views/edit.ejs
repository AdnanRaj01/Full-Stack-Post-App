<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post</title>
</head>
<body>

    <h1>Edit Your Post</h1>

    <form action="/posts/<%= post._id %>?_method=PUT" method="POST">

        <input
            type="text"
            name="username"
            value="<%= post.username %>"
            required
        >

        <br><br>

        <textarea
            name="content"
            rows="5"
            cols="35"
            required><%= post.content %></textarea>

        <br><br>

        <button type="submit">
            Update Post
        </button>

    </form>

    <br>

    <a href="/posts">
        Back to Posts
    </a>

</body>
</html>